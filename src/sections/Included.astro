---

<section id="videos" class="relative pb-0 pt-20 -mt-32 overflow-hidden">
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none overflow-hidden"
  >
    <div
      class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-js-yellow/5 rounded-full blur-[120px] opacity-30"
    >
    </div>
    <div
      class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-js-yellow/5 rounded-full blur-[100px] opacity-30"
    >
    </div>
  </div>

  <div class="container relative z-10 mx-auto px-6">
    <div class="max-w-3xl mx-auto text-center mt-10 mb-10 animate-on-scroll">
      <h2
        class="text-3xl md:text-5xl font-bold font-display mb-0 text-white tracking-tighter leading-[0.9]"
      >
        Revive las charlas<br />y talleres
      </h2>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-6 mb-20"
    >
      {
        videos.map((video, index) => (
          <a
            href={`https://www.youtube.com/watch?v=${video.id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group block animate-on-scroll"
            style={`transition-delay: ${index * 60}ms`}
          >
            <div class="relative overflow-hidden rounded-xl border border-white/10 bg-white/[0.02] transition-all duration-300 ease-out hover:border-js-yellow/40 hover:-translate-y-1 hover:shadow-[0_20px_50px_-12px_rgba(247,223,30,0.2)]">
              <div class="relative aspect-video overflow-hidden">
                <img
                  src={`https://i.ytimg.com/vi/${video.id}/maxresdefault.jpg`}
                  alt={video.title}
                  class="w-full h-full object-cover transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                  <svg
                    class="w-14 h-14 drop-shadow-xl transition-transform duration-300 ease-out scale-75 group-hover:scale-100"
                    viewBox="0 0 64 64"
                    fill="none"
                    aria-hidden="true"
                  >
                    <circle cx="32" cy="32" r="32" fill="rgba(247,223,30,0.9)" />
                    <path d="M26 20 L26 44 L46 32 Z" fill="#1a1a1a" />
                  </svg>
                </div>
                <div class="absolute top-2 left-2">
                  <span
                    class:list={[
                      'text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full backdrop-blur-sm',
                      video.type === 'charla'
                        ? 'bg-js-yellow/90 text-js-black'
                        : 'bg-white/90 text-js-black',
                    ]}
                  >
                    {video.type}
                  </span>
                </div>
              </div>
              <div class="p-3 sm:p-4">
                <h3 class="text-sm sm:text-base font-semibold text-white font-display leading-tight line-clamp-2 group-hover:text-js-yellow transition-colors duration-300">
                  {video.title}
                </h3>
                {video.speaker && (
                  <p class="mt-1.5 text-xs sm:text-sm text-gray-400 group-hover:text-gray-300 transition-colors duration-300">
                    {video.speaker}
                  </p>
                )}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
